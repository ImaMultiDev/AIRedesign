# Copia a `.env` en esta misma carpeta (junto a package.json).
# En monorepos, el `.env` del proyecto debe vivir aquí, no solo en la raíz.

# PostgreSQL (Railway, local, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# NextAuth — obligatorio para el panel admin (openssl rand -base64 32)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Admin: mismo email/contraseña para entrar en /admin/login y para `prisma db seed`
ADMIN_SEED_EMAIL="admin@demo.local"
ADMIN_SEED_PASSWORD="cambia-esto"
