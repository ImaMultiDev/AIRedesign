# Copia a `.env` en esta misma carpeta (junto a package.json).
# En monorepos, el `.env` del proyecto debe vivir aquí, no solo en la raíz.

# PostgreSQL (Railway, local, etc.)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# NextAuth — obligatorio (openssl rand -base64 32)
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (https://cloudinary.com/console)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
# Opcional: prefijo de carpeta (ej. airedesign)
# CLOUDINARY_UPLOAD_FOLDER="airedesign"

# Admin: mismo email/contraseña para /admin/login y `prisma db seed`.
# No uses este email en /login (magic link): el enlace por correo está bloqueado para ese email.
ADMIN_SEED_EMAIL="admin@demo.local"
ADMIN_SEED_PASSWORD="cambia-esto"

# Stripe — suscripción Plus (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
# Price ID del plan Plus (recurring mensual u otro)
STRIPE_PLUS_PRICE_ID="price_..."

# Resend — correo transaccional (https://resend.com)
RESEND_API_KEY=""
# Remitente verificado en Resend, ej: "AIRedesign <notificaciones@tudominio.com>"
EMAIL_FROM=""
