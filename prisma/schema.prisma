// Prisma schema — PostgreSQL (Railway-ready), flujo clásico Prisma 5.x

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
}

/// Estado de suscripción Stripe (Plus)
enum SubscriptionStatus {
  NONE
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
}

enum ProposalStatus {
  SUBMITTED
  IN_REVIEW
  BASIC_READY
  PLUS_IN_PROGRESS
  PLUS_DELIVERED
  ARCHIVED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  /// Solo administradores (login con contraseña). Clientes usan magic link / OAuth.
  password      String?
  image         String?
  role          UserRole  @default(USER)

  stripeCustomerId            String?              @unique
  stripeSubscriptionId        String?              @unique
  subscriptionStatus          SubscriptionStatus   @default(NONE)
  subscriptionCurrentPeriodEnd  DateTime?

  accounts         Account[]
  sessions         Session[]
  proposalRequests ProposalRequest[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Solicitud de propuesta (básica gratuita o completa Plus)
model ProposalRequest {
  id          String         @id @default(cuid())
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String?
  description String         @db.Text
  /// BASIC (gratis) o PLUS (requiere suscripción activa al crear entrega completa)
  tierRequested String       @default("BASIC") // "BASIC" | "PLUS"
  status      ProposalStatus @default(SUBMITTED)

  /// Respuesta resumida para el plan gratuito (texto / notas internas)
  basicSummary String? @db.Text
  /// Presupuesto detallado materiales (Plus), markdown o texto
  plusBudgetDetails String? @db.Text
  /// Ficha técnica PDF (Cloudinary raw)
  technicalPdfUrl     String?
  technicalPdfPublicId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

/// Ejemplos de galería (antes/después) — URLs Cloudinary optimizadas
model Showcase {
  id             String   @id @default(cuid())
  title          String
  category       String
  description    String?  @db.Text
  beforeUrl      String
  afterUrl       String
  beforePublicId String?
  afterPublicId  String?
  /// Contenido premium (Plan Plus): presupuesto detallado
  plusBudgetDetails    String? @db.Text
  /// Ficha técnica PDF (Cloudinary raw); descarga Plus vía API
  technicalPdfUrl      String?
  technicalPdfPublicId String?
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  productPins ShowcaseProductPin[]

  @@index([category])
  @@index([sortOrder])
  @@index([isActive])
}

/// Puntos «Shop the look» sobre la imagen «después» (coords 0-1 desde esquina superior izquierda)
model ShowcaseProductPin {
  id         String   @id @default(cuid())
  showcaseId String
  showcase   Showcase @relation(fields: [showcaseId], references: [id], onDelete: Cascade)
  positionX  Float
  positionY  Float
  /// Nombre del producto / mueble (común a todas las ofertas del punto)
  name       String
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  offers ShowcaseProductPinOffer[]

  @@index([showcaseId])
}

/// Variante de compra (tienda + precio + enlace) por cada pin — comparador multi-tienda
model ShowcaseProductPinOffer {
  id          String             @id @default(cuid())
  pinId       String
  pin         ShowcaseProductPin @relation(fields: [pinId], references: [id], onDelete: Cascade)
  storeName   String
  /// Marca para icono reconocible (amazon, ikea, other…)
  storeBrand  String             @default("other")
  /// Miniatura del artículo en la tienda (URL https)
  thumbnailUrl String?           @db.Text
  /// Texto mostrado («899 €», «desde 129 €/m»…)
  priceLabel  String
  /// Valor numérico para ordenar de menor a mayor (misma moneda por producto)
  sortPrice   Float
  buyUrl      String             @db.Text
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([pinId])
}
